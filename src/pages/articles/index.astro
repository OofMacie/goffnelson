---
import Layout from '../../layouts/Layout.astro';
import NavBar from '../../components/NavBar.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles');
const articles = allArticles.sort((a, b) => b.data.publishDate.localeCompare(a.data.publishDate));
---

<Layout title="News & Articles | Goff Nelson Memorial Library">
  <NavBar />
  <main class="max-w-4xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold mb-2">News & Articles</h1>
    <p class="text-gray-600 mb-10">Updates and announcements from Goff Nelson Memorial Library.</p>

    {articles.length === 0 && (
      <p class="text-gray-500">No articles yet. Check back soon!</p>
    )}

    <div class="flex flex-col gap-6">
      {articles.map((article) => (
        <a href={`/articles/${article.id}`} class="group block border border-gray-200 rounded-xl p-6 hover:border-blue-400 hover:shadow-md transition-all duration-200">
          <p class="text-xs text-gray-400 mb-1">
            {new Date(article.data.publishDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            &nbsp;&mdash;&nbsp;{article.data.author}
          </p>
          <h2 class="text-xl font-semibold group-hover:text-blue-600 transition-colors">{article.data.title}</h2>
          <p class="text-gray-600 mt-2">{article.data.description}</p>
        </a>
      ))}
    </div>
  </main>
</Layout>
