---
import Layout from '../../layouts/Layout.astro'
import NavBar from '../../components/NavBar.astro'
import { useStoryblokApi, renderRichText } from '@storyblok/astro'

const storyblokApi = useStoryblokApi()

const { data } = await storyblokApi.get('cdn/stories', {
  version: import.meta.env.DEV ? 'draft' : 'published',
  starts_with: 'articles/',
  sort_by: 'content.publish_date:desc',
})

const articles = data.stories.map((s: any) => s.content)

function formatDate(dateStr: string) {
  return new Date(dateStr + 'T00:00:00').toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  })
}
---

<Layout title="Articles | Goff Nelson Memorial Library" description="News and updates from Goff Nelson Memorial Library.">
  <NavBar />
  <main class="articles-page">
    <div class="page-header">
      <h1>Articles &amp; News</h1>
      <p>Updates and announcements from Goff Nelson Memorial Library</p>
    </div>

    {articles.length > 0 ? (
      <ul class="articles-list">
        {articles.map((article: any) => (
          <li class="article-card">
            <div class="article-meta">
              <span class="article-date">{formatDate(article.publish_date)}</span>
              <span class="separator">·</span>
              <span class="article-author">{article.author ?? 'Goff Nelson Library Staff'}</span>
            </div>
            <h2 class="article-title">{article.title}</h2>
            <p class="article-description">{article.description}</p>
            {article.body && (
              <div class="article-body" set:html={renderRichText(article.body)} />
            )}
          </li>
        ))}
      </ul>
    ) : (
      <p class="no-content">No articles yet. Check back soon!</p>
    )}
  </main>
</Layout>

<style>
  .articles-page {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem 1rem 4rem;
  }
  .page-header { margin-bottom: 2.5rem; }
  .page-header h1 { font-size: 2rem; margin-bottom: 0.5rem; }
  .page-header p { color: #555; }
  .articles-list { list-style: none; display: flex; flex-direction: column; gap: 2rem; }
  .article-card {
    border-bottom: 1px solid #e0e0e0;
    padding-bottom: 2rem;
  }
  .article-card:last-child { border-bottom: none; }
  .article-meta {
    display: flex;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: #666;
    margin-bottom: 0.5rem;
  }
  .article-title { font-size: 1.35rem; font-weight: 600; margin-bottom: 0.5rem; line-height: 1.3; }
  .article-description { color: #444; line-height: 1.65; }
  .article-body { margin-top: 1rem; color: #333; line-height: 1.7; }
  .no-content { color: #666; font-style: italic; }
</style>
