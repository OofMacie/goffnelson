---
import Layout from '../../layouts/Layout.astro';
import NavBar from '../../components/NavBar.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map((article) => ({ params: { slug: article.id }, props: { article } }));
}

const { article } = Astro.props;
const { Content } = await render(article);
---

<Layout title={`${article.data.title} | Goff Nelson Memorial Library`}>
  <NavBar />
  <main class="max-w-3xl mx-auto px-4 py-12">
    <a href="/articles" class="text-sm text-blue-600 hover:underline mb-6 inline-block">&larr; All Articles</a>

    <p class="text-sm text-gray-400 mb-2">
      {new Date(article.data.publishDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      &nbsp;&mdash;&nbsp;{article.data.author}
    </p>

    <h1 class="text-4xl font-bold mb-8">{article.data.title}</h1>

    <div class="prose prose-lg max-w-none">
      <Content />
    </div>
  </main>
</Layout>
