---
import Layout from '../../layouts/Layout.astro';
import NavBar from '../../components/NavBar.astro';
import { getCollection } from 'astro:content';

const allEvents = await getCollection('events');
const events = allEvents.sort((a, b) => a.data.date.localeCompare(b.data.date));

const categoryLabels: Record<string, string> = {
  'book-club': 'Book Club',
  'childrens': "Children's",
  'teen': 'Teen',
  'adult': 'Adult',
  'community': 'Community',
  'other': 'Other',
};
---

<Layout title="Events | Goff Nelson Memorial Library">
  <NavBar />
  <main class="max-w-4xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold mb-2">Events</h1>
    <p class="text-gray-600 mb-10">Upcoming programs and events at Goff Nelson Memorial Library.</p>

    {events.length === 0 && (
      <p class="text-gray-500">No upcoming events. Check back soon!</p>
    )}

    <div class="flex flex-col gap-6">
      {events.map((event) => (
        <a href={`/events/${event.id}`} class="group block border border-gray-200 rounded-xl p-6 hover:border-blue-400 hover:shadow-md transition-all duration-200">
          <div class="flex items-center gap-2 mb-2">
            <span class="text-xs font-semibold uppercase tracking-wide bg-blue-100 text-blue-700 px-2 py-0.5 rounded-full">
              {categoryLabels[event.data.category] ?? event.data.category}
            </span>
          </div>
          <h2 class="text-xl font-semibold group-hover:text-blue-600 transition-colors">{event.data.title}</h2>
          <p class="text-sm text-gray-500 mt-1">
            {new Date(event.data.date).toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' })}
            {event.data.time && <span> &mdash; {event.data.time}</span>}
          </p>
          {event.data.location && <p class="text-sm text-gray-500">{event.data.location}</p>}
          <p class="text-gray-600 mt-3">{event.data.description}</p>
        </a>
      ))}
    </div>
  </main>
</Layout>
