---
import Layout from '../../layouts/Layout.astro';
import NavBar from '../../components/NavBar.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const events = await getCollection('events');
  return events.map((event) => ({ params: { slug: event.id }, props: { event } }));
}

const { event } = Astro.props;
const { Content } = await render(event);

const categoryLabels: Record<string, string> = {
  'book-club': 'Book Club',
  'childrens': "Children's Program",
  'teen': 'Teen Program',
  'adult': 'Adult Program',
  'community': 'Community Event',
  'other': 'Other',
};
---

<Layout title={`${event.data.title} | Goff Nelson Memorial Library`}>
  <NavBar />
  <main class="max-w-3xl mx-auto px-4 py-12">
    <a href="/events" class="text-sm text-blue-600 hover:underline mb-6 inline-block">&larr; All Events</a>

    <span class="text-xs font-semibold uppercase tracking-wide bg-blue-100 text-blue-700 px-2 py-0.5 rounded-full">
      {categoryLabels[event.data.category] ?? event.data.category}
    </span>

    <h1 class="text-4xl font-bold mt-3 mb-2">{event.data.title}</h1>

    <div class="text-gray-500 text-sm space-y-1 mb-8">
      <p>
        <strong>Date:</strong>{' '}
        {new Date(event.data.date).toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' })}
        {event.data.endDate && <span> – {new Date(event.data.endDate).toLocaleDateString('en-US', { month: 'long', day: 'numeric' })}</span>}
      </p>
      {event.data.time && <p><strong>Time:</strong> {event.data.time}</p>}
      {event.data.location && <p><strong>Location:</strong> {event.data.location}</p>}
    </div>

    <div class="prose prose-lg max-w-none">
      <Content />
    </div>
  </main>
</Layout>
