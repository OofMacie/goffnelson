---
interface Props {
  title?: string
  description?: string
  image?: string
  canonicalURL?: string
  type?: 'website' | 'article'
  noindex?: boolean
}

const SITE_URL = 'https://goffnelsonlibrary.org'
const SITE_NAME = 'Goff-Nelson Memorial Library'
const DEFAULT_DESCRIPTION =
  "Goff-Nelson Memorial Library serves Tupper Lake, NY with books, eBooks, audiobooks, DVDs, museum passes, community events, children's programs, teen programs, and free library cards."
const DEFAULT_IMAGE = `${SITE_URL}/assets/logo2.png`
const DEFAULT_KEYWORDS =
  'Goff-Nelson Memorial Library, Tupper Lake library, public library, books, eBooks, audiobooks, DVDs, library events, children programs, teen programs, Adirondacks library, library card, community resources, Tupper Lake NY'

const {
  title = SITE_NAME,
  description = DEFAULT_DESCRIPTION,
  image = DEFAULT_IMAGE,
  canonicalURL = new URL(Astro.url.pathname, SITE_URL).toString(),
  type = 'website',
  noindex = false,
} = Astro.props

const pageTitle = title === SITE_NAME ? title : `${title} | ${SITE_NAME}`

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Library',
  name: SITE_NAME,
  alternateName: 'Goff Nelson Memorial Library',
  description: DEFAULT_DESCRIPTION,
  url: SITE_URL,
  logo: DEFAULT_IMAGE,
  image: DEFAULT_IMAGE,
  telephone: '+1-518-359-9421',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '41 Lake Street',
    addressLocality: 'Tupper Lake',
    addressRegion: 'NY',
    postalCode: '12986',
    addressCountry: 'US',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 44.2273,
    longitude: -74.4599,
  },
  openingHoursSpecification: [
    { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Monday', 'Wednesday', 'Friday'], opens: '10:00', closes: '18:00' },
    { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Tuesday', 'Thursday'], opens: '10:00', closes: '20:00' },
    { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Saturday'], opens: '10:00', closes: '14:00' },
  ],
  sameAs: [
    'https://www.facebook.com/GoffNelsonMemorialLibrary',
  ],
  areaServed: {
    '@type': 'City',
    name: 'Tupper Lake',
    containedIn: {
      '@type': 'State',
      name: 'New York',
    },
  },
}
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Core -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary SEO -->
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={DEFAULT_KEYWORDS} />
    <meta name="author" content={SITE_NAME} />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1'} />
    <meta name="revisit-after" content="7 days" />
    <meta name="language" content="English" />
    <meta name="rating" content="general" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Geographic / Local SEO -->
    <meta name="geo.region" content="US-NY" />
    <meta name="geo.placename" content="Tupper Lake, New York" />
    <meta name="geo.position" content="44.2273;-74.4599" />
    <meta name="ICBM" content="44.2273, -74.4599" />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={image} />
    <meta property="og:image:alt" content={`${SITE_NAME} logo`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@GoffNelsonLib" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />
    <meta name="twitter:image:alt" content={`${SITE_NAME} logo`} />

    <!-- Dublin Core -->
    <meta name="DC.title" content={pageTitle} />
    <meta name="DC.description" content={description} />
    <meta name="DC.creator" content={SITE_NAME} />
    <meta name="DC.language" content="en" />
    <meta name="DC.coverage" content="Tupper Lake, New York, USA" />
    <meta name="DC.type" content="Service" />
    <meta name="DC.format" content="text/html" />

    <!-- Icons -->
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/icon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- PWA / Theme -->
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#2d6a4f" />
    <meta name="msapplication-TileColor" content="#2d6a4f" />
    <meta name="color-scheme" content="light" />

    <!-- Performance hints -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="dns-prefetch" href="https://cefls.ent.sirsi.net" />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />

    <!-- Styles -->
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
